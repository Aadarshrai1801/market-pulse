# Copy this file to .env and fill in real values. .env is already in
# .gitignore - never commit real credentials.

# --- MongoDB (required) ---
# Get this from Atlas: Database > Connect > Drivers > Python. It looks like
#   mongodb+srv://<username>:<password>@<cluster-address>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-address>.mongodb.net/?retryWrites=true&w=majority
MONGO_DB_NAME=intellicrop

# --- Flask (recommended in production) ---
SECRET_KEY=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# --- Google OAuth (optional) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
GOOGLE_DEFAULT_ROLE=viewer
